generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Text
  email        String   @unique
  passwordHash String   @map("password_hash") @db.Text
  fullName     String   @map("full_name")
  createdAt    DateTime @default(now()) @map("created_at")
  quizzes      Quiz[]

  @@map("admin_users")
}

model Quiz {
  id               String        @id @default(uuid()) @db.Text
  title            String
  description      String        @default("") @db.Text
  status           String        @default("draft")
  createdBy        String        @map("created_by") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  creator          AdminUser     @relation(fields: [createdBy], references: [id])
  questions        Question[]
  gameSessions     GameSession[]

  @@map("quizzes")
}

model Question {
  id              String   @id @default(uuid()) @db.Text
  quizId          String   @map("quiz_id") @db.Text
  orderNo         Int      @map("order_no")
  questionText    String   @map("question_text") @db.Text
  imageUrl        String?  @map("image_url") @db.Text
  optionA         String   @map("option_a") @db.Text
  optionB         String   @map("option_b") @db.Text
  optionC         String   @map("option_c") @db.Text
  optionD         String   @map("option_d") @db.Text
  correctOption   String   @map("correct_option")
  durationSeconds Int      @default(20) @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, orderNo])
  @@map("questions")
}

model GameSession {
  id                   String                @id @default(uuid()) @db.Text
  quizId               String                @map("quiz_id") @db.Text
  pinCode              String                @unique @map("pin_code")
  status               String                @default("waiting")
  currentQuestionIndex Int                   @default(0) @map("current_question_index")
  startedAt            DateTime?             @map("started_at")
  endedAt              DateTime?             @map("ended_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  quiz                 Quiz                  @relation(fields: [quizId], references: [id])
  participants         Participant[]
  submissions          AnswerSubmission[]
  snapshots            LeaderboardSnapshot[]

  @@map("game_sessions")
}

model Participant {
  id          String               @id @default(uuid()) @db.Text
  sessionId   String               @map("session_id") @db.Text
  displayName String               @map("display_name")
  score       Int                  @default(0)
  currentRank Int                  @default(0) @map("current_rank")
  connected   Boolean              @default(true)
  joinedAt    DateTime             @default(now()) @map("joined_at")
  session     GameSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submissions AnswerSubmission[]
  snapshots   LeaderboardSnapshot[]

  @@map("participants")
}

model AnswerSubmission {
  id             String      @id @default(uuid()) @db.Text
  sessionId      String      @map("session_id") @db.Text
  participantId  String      @map("participant_id") @db.Text
  questionId     String      @map("question_id") @db.Text
  selectedOption String      @map("selected_option")
  isCorrect      Boolean     @map("is_correct")
  responseTimeMs Int         @map("response_time_ms")
  scoreAwarded   Int         @default(0) @map("score_awarded")
  submittedAt    DateTime    @default(now()) @map("submitted_at")
  session        GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
  @@map("answer_submissions")
}

model LeaderboardSnapshot {
  id            String      @id @default(uuid()) @db.Text
  sessionId     String      @map("session_id") @db.Text
  questionId    String?     @map("question_id") @db.Text
  rankNo        Int         @map("rank_no")
  participantId String      @map("participant_id") @db.Text
  score         Int
  createdAt     DateTime    @default(now()) @map("created_at")
  session       GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("leaderboard_snapshots")
}
