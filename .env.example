# Copy to .env for local dev, or set these as environment variables on your host.

# Supabase Postgres connection (use the connection POOLER, not the direct host).
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Public URL of the deployed app. Used to build join/QR links.
# Local: http://localhost:5173  |  Production: https://your-app.onrender.com
APP_URL=http://localhost:5173

# Set automatically by most hosts. Defaults to 3002 locally.
# PORT=3002

# Set to "production" on the host so the server also serves the built frontend.
# NODE_ENV=production
